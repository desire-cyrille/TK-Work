generator client {
  provider      = "prisma-client-js"
  // Vercel serverless peut être arm64 (Graviton) : inclure les deux ABI courantes
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Paires clé/valeur côté serveur (réglages, feature flags, etc.)
model AppKv {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

/// Compte cloud pour connexion et droits (mot de passe hashé côté serveur).
model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String         @map("password_hash")
  role               UserRole       @default(USER)
  mustChangePassword Boolean        @default(false) @map("must_change_password")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  snapshot           UserSnapshot?

  @@map("users")
}

/// Une seule copie des données métier partagée par tous les comptes (sync « nuage »).
model WorkspaceSnapshot {
  id        String   @id
  payload   Json     @default("{}")
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("workspace_snapshots")
}

/// Dernière copie des entrées localStorage (JSON) pour un utilisateur.
model UserSnapshot {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload   Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("user_snapshots")
}

/// Verrou d'édition (une clé : biens, devis:uuid, projet:uuid).
model WorkspaceLock {
  resourceKey  String   @id @map("resource_key")
  holderUserId String   @map("holder_user_id")
  holderEmail  String   @map("holder_email")
  holderLabel  String   @map("holder_label")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("workspace_locks")
}
