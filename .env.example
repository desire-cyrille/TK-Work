# Copiez ce fichier en .env et remplissez DATABASE_URL (Neon Dashboard → Connection string).
# Puis : npm run db:migrate   (local, applique prisma/migrations sur Neon)
# Prod Vercel : une fois, après déploiement : npm run db:deploy (avec DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Secret pour les jetons JWT (compte nuage / sync). Au moins 32 caractères.
# Ex. : openssl rand -base64 48
# À ajouter aussi dans Vercel → Environment Variables (Production + Preview si besoin).
JWT_SECRET="remplacez-par-une-longue-chaine-aleatoire-au-moins-32-caracteres"

# Inscription depuis l’écran « Première utilisation » : mettre à "false" en prod
# quand seul l’admin crée les comptes (voir /admin/utilisateurs).
# ALLOW_PUBLIC_SIGNUP=false

# Hébergement dans un sous-chemin du site (ex. https://groupe.fr/app/) :
# au build : VITE_BASE_PATH=/app/
# VITE_BASE_PATH=/

# Une fois la base migrée, créer le compte admin (e-mail et mot de passe dans l’environnement uniquement) :
# ADMIN_EMAIL=admin@local ADMIN_PASSWORD='...' npm run bootstrap-admin
